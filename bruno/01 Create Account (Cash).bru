meta {
  name: 01 Create Account (Cash)
  type: http
  seq: 1
}

post {
  url: {{baseUrl}}/v1/accounts
  body: json
  auth: none
}

body:json {
  {
    "name": "Cash",
    "type": "asset",
    "currency": "USD"
  }
}

script:post-response {
  bru.setVar("cashId", res.body.id);
}

assert {
  res.status: eq 201
  res.body.type: eq asset
}
