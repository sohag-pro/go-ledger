# Database
DATABASE_URL=postgres://ledger:ledger@localhost:5432/ledger?sslmode=disable

# App
APP_ENV=development
OTEL_SERVICE_NAME=go-ledger

# Safe-by-default deployment (ADR-015). DEMO_MODE is the master switch for all
# demo behavior: the public demo api key and the periodic demo-data seeder
# are both off unless it is explicitly true. SEED_ENABLED only takes effect
# when DEMO_MODE is also true. DEMO_API_KEY defaults to a published, public
# value meant for the console and playground; the server refuses to boot with
# that value when APP_ENV=production.
#
# Production checklist:
#   - APP_ENV=production
#   - leave DEMO_MODE unset (or explicitly false)
#   - either leave DEMO_API_KEY unset with demo mode off, or set it to a real,
#     private value if demo mode is ever turned on for a non-public deployment
DEMO_MODE=false
SEED_ENABLED=false
DEMO_API_KEY=

# Multi-currency (ADR-014). DEFAULT_CURRENCY is the currency stamped on a new
# account when the caller does not specify one, and on the demo seeder's
# accounts and postings.
DEFAULT_CURRENCY=USD

# FX_RATES seeds the append-only fx_rates table at boot. Comma-separated
# "BASE:QUOTE=rate/spreadBps" entries, for example:
# FX_RATES=USD:EUR=0.9200/25,USD:BDT=110.50/50
# Leave unset if the deployment does not need cross-currency conversion.
FX_RATES=

# Approval workflows (ADR-025). APPROVAL_ENABLED is the master switch: off
# (the default) means a post, convert, or reversal is never held, no matter
# how large. APPROVAL_THRESHOLDS is a comma-separated "CCY:amount" list, in
# minor units, judged against the single largest leg per currency, for
# example:
# APPROVAL_THRESHOLDS=USD:100000,EUR:90000
# APPROVAL_REQUIRE_DIFFERENT_ACTOR enforces four-eyes: the tenant that created
# a pending cannot also be the one who approves it. PENDING_TTL is how long an
# undecided pending is left before the background sweep expires it;
# PENDING_SWEEP_INTERVAL is how often that sweep runs.
APPROVAL_ENABLED=false
APPROVAL_THRESHOLDS=
APPROVAL_REQUIRE_DIFFERENT_ACTOR=false
PENDING_TTL=72h
PENDING_SWEEP_INTERVAL=1h

# Tracing: point at Jaeger locally (make jaeger), or Honeycomb remotely.
# Leave the endpoint unset to disable tracing (a warn line is logged at startup).
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318

# For eyeballing spans on stdout without a collector (endpoint must be unset):
# OTEL_TRACES_EXPORTER=console

# Honeycomb (remote): set the endpoint and the team key header.
# OTEL_EXPORTER_OTLP_ENDPOINT=https://api.honeycomb.io
# OTEL_EXPORTER_OTLP_HEADERS=x-honeycomb-team=YOUR_INGEST_KEY

# Production sampling (keeps the Honeycomb free tier in budget):
# OTEL_TRACES_SAMPLER=parentbased_traceidratio
# OTEL_TRACES_SAMPLER_ARG=0.25
