# Managed by Ansible (ADR-016). Weekly full base backup, triggered by
# pgbackrest-full.timer.
[Unit]
Description=pgBackRest full backup for the go-ledger stanza
After=postgresql.service
Requires=postgresql.service

[Service]
Type=oneshot
User=postgres
ExecStart=/usr/bin/pgbackrest --stanza={{ pgbackrest_stanza }} --type=full backup
