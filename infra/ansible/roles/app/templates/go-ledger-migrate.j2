#!/bin/sh
# Pre-swap migration wrapper (Task 5.6b, audit A4.3).
#
# The deploy pipeline (.github/workflows/deploy.yml) runs this, over a
# narrowly scoped sudoers NOPASSWD rule, against the freshly uploaded
# go-ledger.new BEFORE it is swapped into place: it loads the same env file
# the go-ledger systemd unit uses (so DATABASE_URL matches production), then
# execs the new binary's own `migrate` subcommand. A migration failure here
# exits non-zero, which aborts the deploy job before the swap-and-restart
# step ever runs, so a bad migration never leaves new code running against
# an unmigrated database or vice versa.
#
# Deliberately installed root-owned outside {{ app_dir }}: {{ app_dir }} is
# owned by {{ deploy_user }} so CI can upload binaries there, and a wrapper
# script the deploy user could overwrite would turn this sudoers rule into
# an unrestricted escalation path (replace the script, sudo runs whatever it
# says) instead of the narrow one it is meant to be. Root ownership of THIS
# script only protects it from being tampered with by {{ deploy_user }}; it
# does not mean the migrate it runs should execute as root.
#
# Runs as {{ app_user }}, not root: the sudoers Runas_Spec is
# `({{ app_user }})`, so sudo executes this whole script, and everything it
# execs, as {{ app_user }}, the same sandboxed system user the systemd unit
# runs the service as. go-ledger.new lives in {{ app_dir }}, which
# {{ deploy_user }} fully owns and CI overwrites on every push, so running
# migrate as root would let a leaked deploy key run arbitrary code as root;
# running it as {{ app_user }} caps that blast radius at what the service
# already has. {{ env_file }} is root:{{ app_user }} 0640, so {{ app_user }}
# can read DATABASE_URL from it without needing root.
set -eu
set -a
. {{ env_file }}
set +a
exec {{ app_dir }}/go-ledger.new migrate "$@"
